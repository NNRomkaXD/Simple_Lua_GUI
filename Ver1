        end
    end
    
    if Movement.Mode == "BV" and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") and Movement.BodyVelocity and Movement.BodyVelocity.Parent then
        local moveDir = LocalPlayer.Character.Humanoid.MoveDirection
        
        Movement.BodyVelocity.MaxForce = Vector3.new(1e6, 0, 1e6)
        if moveDir.Magnitude > 0 then
            Movement.BodyVelocity.Velocity = moveDir * Movement.Speed
        else
            Movement.BodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    elseif Movement.Mode == "WS" and Movement.BodyVelocity then
        Movement.BodyVelocity.MaxForce = Vector3.zero
        Movement.BodyVelocity.Velocity = Vector3.zero
    end
    
    if TeleportAll.Enabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local root = LocalPlayer.Character.HumanoidRootPart
        local targetPos = (root.CFrame * CFrame.new(0, 0, -TeleportAll.Distance)).Position
        
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.CFrame = CFrame.new(targetPos)
            end
        end
    end
end)

LocalPlayer.CharacterAdded:Connect(function(character)
    character:WaitForChild("Humanoid")
    task.wait(0.1)
    
    if Movement.Speed ~= 16 or Movement.JumpPower ~= 50 or Movement.Gravity ~= 196.2 then
        updateMovementStats()
    end
    
    if Invisible.State then
        task.wait(0.1)
        toggleInvisibility()
    end
    
    if Noclip.Enabled then
        updateNoclip(true)
    end
    
    if Hitbox.Enabled then
        updateHitbox(true)
    end
    
    if Flight.Enabled then
        Flight.Enabled = false
    end
    
    setupMovementPhysics(character)
end)

LocalPlayer.CharacterRemoving:Connect(function()
    if Flight.Enabled then
        Flight.Enabled = false
        if Flight.BodyVelocity then
            Flight.BodyVelocity:Destroy()
            Flight.BodyVelocity = nil
        end
        if Flight.BodyGyro then
            Flight.BodyGyro:Destroy()
            Flight.BodyGyro = nil
        end
    end
    
    if Invisible.State then
        Invisible.State = false
        setCharacterTransparency(0)
        local inv = workspace:FindFirstChild('invischair')
        if inv then
            pcall(function() inv:Destroy() end)
        end
        stopSeatReturnHeartbeat()
    end
end)

if LocalPlayer.Character then
    task.spawn(setupMovementPhysics, LocalPlayer.Character)
end

updateMovementStats()
updateNoclip(Noclip.Enabled)
updateInfiniteJump(InfiniteJump.Enabled)

ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
