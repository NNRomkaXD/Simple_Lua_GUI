local function updateHitbox(state)
    if state then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Size = Vector3.new(Hitbox.HeadSize, Hitbox.HeadSize, Hitbox.HeadSize)
                    hrp.Transparency = 1
                    hrp.CanCollide = false
                end
            end
        end
    else
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Size = Vector3.new(2, 2, 1)
                    hrp.Transparency = 0
                    hrp.CanCollide = true
                end
            end
        end
    end
end

local function setCharacterTransparency(transparency)
    local character = LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.Transparency = transparency
            end
        end
    end
end

local function stopSeatReturnHeartbeat()
    if Invisible.Connection then
        Invisible.Connection:Disconnect()
        Invisible.Connection = nil
    end
end

local function toggleInvisibility()
    if not Invisible.EnabledToggle then return end
    
    Invisible.State = not Invisible.State
    local character = LocalPlayer.Character
    if not character then return end
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return end

    if Invisible.State then
        setCharacterTransparency(Invisible.Transparency)
        local savedpos = humanoidRootPart.CFrame
        
        task.wait(0.05)
        pcall(function() character:MoveTo(Invisible.SeatTeleport) end)
        task.wait(0.05)

        local Seat = Instance.new('Seat')
        Seat.Parent = workspace
        Seat.Anchored = false
        Seat.CanCollide = false
        Seat.Name = 'invischair'
        Seat.Transparency = 1
        Seat.Position = Invisible.SeatTeleport

        local Weld = Instance.new("Weld")
        Weld.Part0 = Seat
        local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        
        if torso then
            Weld.Part1 = torso
            Weld.Parent = Seat
            task.wait()
            pcall(function() Seat.CFrame = savedpos end)
        else
            Seat:Destroy()
        end
    else
        setCharacterTransparency(0)
        task.spawn(function()
            local inv = workspace:FindFirstChild('invischair')
            if inv then
                pcall(function() inv:Destroy() end)
            end
        end)
        stopSeatReturnHeartbeat()
    end
end

local function updateNoclip(state)
    if Noclip.Connection then
        Noclip.Connection:Disconnect()
        Noclip.Connection = nil
    end
    
    if state then
        Noclip.Connection = RunService.Stepped:Connect(function()
            if LocalPlayer.Character then
                for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                    if v:IsA("BasePart") and v.CanCollide then
                        v.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function updateMovementStats()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        local hum = LocalPlayer.Character.Humanoid
        hum.JumpPower = Movement.JumpPower
        if Movement.Mode == "BV" then
            hum.WalkSpeed = 16
        else
            hum.WalkSpeed = Movement.Speed
        end
    end
    workspace.Gravity = Movement.Gravity
end

local function toggleMovementMode()
    Movement.Mode = (Movement.Mode == "WS" and "BV" or "WS")
    updateMovementStats()
end

local function setupMovementPhysics(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end
    if hrp:FindFirstChild("MovementBV") then hrp.MovementBV:Destroy() end
    
    Movement.BodyVelocity = Instance.new("BodyVelocity")
    Movement.BodyVelocity.Name = "MovementBV"
    Movement.BodyVelocity.MaxForce = Vector3.zero
    Movement.BodyVelocity.Velocity = Vector3.zero
    Movement.BodyVelocity.Parent = hrp
    
    task.wait(0.1)
    updateMovementStats()
end

local function updateInfiniteJump(state)
    if InfiniteJump.Connection then
        InfiniteJump.Connection:Disconnect()
        InfiniteJump.Connection = nil
    end
    
    if state then
        InfiniteJump.Connection = UserInputService.JumpRequest:Connect(function()
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                local humanoid = LocalPlayer.Character.Humanoid
                if humanoid:GetState() ~= Enum.HumanoidStateType.Dead then
                    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end)
    end
end

